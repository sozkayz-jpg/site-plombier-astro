---
const links = [
  { href: 'index.html', label: 'Accueil' },
  { href: 'services.html', label: 'Services' },
  { href: 'a-propos.html', label: 'À Propos' },
  { href: 'faq.html', label: 'FAQ' },
  { href: 'contact.html', label: 'Contact' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) => {
  if (href === 'index.html' && (pathname === '/' || pathname === '/index.html')) return true;
  return pathname.includes(href);
};
---

<nav class="nav-desktop" role="navigation" aria-label="Navigation principale">
  <ul class="nav__list">
    {links.map(link => (
      <li><a href={link.href} class="nav__link" aria-current={isActive(link.href) ? 'page' : undefined}>{link.label}</a></li>
    ))}
  </ul>
  <a href="tel:+33123456789" class="btn btn--cta header__cta" aria-label="Appeler pour une urgence">01 23 45 67 89</a>
</nav>

<button id="menuToggle" class="nav-toggle" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="navMobile">
  <span></span><span></span><span></span>
</button>

<nav id="navMobile" class="nav nav-mobile" role="navigation" aria-label="Navigation mobile">
  <ul class="nav__list">
    {links.map(link => (
      <li><a href={link.href} class="nav__link">{link.label}</a></li>
    ))}
    <li><a href="tel:+33123456789" class="btn btn--cta">01 23 45 67 89</a></li>
  </ul>
</nav>
<div id="navOverlay" class="nav-overlay"></div>
